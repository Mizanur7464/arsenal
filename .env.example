# Copy to .env and fill in — NEVER commit .env or share it

HEADLESS=false
PAGE_TIMEOUT_MS=60000
DRY_RUN=true

# Buyer login (required)
ACCOUNT_EMAIL=your_email@example.com
ACCOUNT_PASSWORD=your_password_here

# Telegram — get chat id from /start (shown in terminal) or @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# One buyer:
TELEGRAM_CHAT_ID=your_chat_id_number
# Or many buyers (comma-separated, no spaces required):
# TELEGRAM_CHAT_IDS=7820675619,7384232467
# Anyone can use /start_on /stop (default open). Lock to .env list only:
# TELEGRAM_OPEN_ACCESS=false
TELEGRAM_OPEN_ACCESS=true
# If Telegram API blocked: VPN on PC, or:
# TELEGRAM_PROXY=socks5://127.0.0.1:1080

# 2captcha.com — Queue-it image captcha (required for auto queue)
TWOCAPTCHA_API_KEY=your_2captcha_api_key_here

# Filters (override config.yaml when set)
TICKET_EXCHANGE=true
SEATS_TOGETHER=false
